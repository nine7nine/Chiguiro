<?xml version="1.0" encoding="UTF-8"?>
<schemalist gettext-domain="@BIN_NAME@">
  <schema id="@KGX_APPLICATION_ID_RAW@" path="@KGX_APPLICATION_PATH_RAW@">
    <key name="font-scale" type="d">
      <range min="0.5" max="4.0"/>
      <default>1.0</default>
    </key>
    <key name="custom-font" type="s">
      <default>""</default>
    </key>
    <key name="use-system-font" type="b">
      <default>true</default>
    </key>
    <key name="shell" type="as">
      <default>[]</default>
    </key>
    <key name="ignore-scrollback-limit" type="b">
      <default>false</default>
    </key>
    <key name="scrollback-lines" type="x">
      <default>10000</default>
    </key>
    <key name="last-window-size" type="(ii)">
      <default>(-1, -1)</default>
    </key>
    <key name="last-window-maximised" type="b">
      <default>false</default>
    </key>
    <key name="restore-window-size" type="b">
      <default>true</default>
    </key>
    <key name="audible-bell" type="b">
      <default>true</default>
    </key>
    <key name="visual-bell" type="b">
      <default>true</default>
    </key>
    <key name="software-flow-control" type="b">
      <default>false</default>
    </key>
    <key name="transparency" type="b">
      <default>false</default>
    </key>
    <key name="transparency-level" type="d">
      <range min="0.0" max="1.0"/>
      <default>0.04</default>
    </key>
    <key name="glass-opacity" type="d">
      <range min="0.0" max="1.0"/>
      <default>0.94</default>
    </key>
    <key name="glass-color" type="s">
      <default>'#1b1b1f'</default>
    </key>
    <key name="use-glass-bg" type="b">
      <default>true</default>
    </key>
    <key name="accent-color" type="s">
      <default>'#3584e4'</default>
    </key>
    <key name="edge-overscroll" type="b">
      <default>true</default>
    </key>
    <key name="edge-overscroll-color" type="s">
      <default>''</default>
    </key>
    <key name="edge-privilege" type="b">
      <default>true</default>
    </key>
    <key name="edge-privilege-color" type="s">
      <default>'#d940a6'</default>
    </key>
    <key name="edge-overscroll-style" type="i">
      <range min="0" max="1"/>
      <default>1</default>
    </key>
    <key name="edge-thickness" type="i">
      <range min="2" max="20"/>
      <default>20</default>
    </key>
    <key name="edge-speed" type="d">
      <range min="0.1" max="3.0"/>
      <default>0.3</default>
    </key>
    <key name="edge-pulse-speed" type="d">
      <range min="0.1" max="5.0"/>
      <default>0.8</default>
    </key>
    <key name="edge-pulse-depth" type="d">
      <range min="0.0" max="1.0"/>
      <default>0.5</default>
    </key>
    <key name="edge-tail-length" type="d">
      <range min="0.1" max="3.0"/>
      <default>0.9</default>
    </key>
    <key name="edge-burst-count" type="i">
      <range min="1" max="8"/>
      <default>8</default>
    </key>
    <key name="edge-burst-spread" type="d">
      <range min="0.5" max="5.0"/>
      <default>3.1</default>
    </key>
    <key name="edge-privilege-direction" type="i">
      <range min="0" max="1"/>
      <default>0</default>
    </key>
    <key name="process-glass-colors" type="a{ss}">
      <default>{}</default>
    </key>
    <key name="livery" type="s">
      <default>@KGX_LIVERY_UUID_KGX@</default>
    </key>
    <key name="custom-liveries" type="a{sv}">
      <default>{}</default>
    </key>
  </schema>
</schemalist>
