<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <template class="KgxWindow" parent="AdwApplicationWindow">
    <property name="title" translatable="yes">Chigüiro</property>
    <binding name="translucent">
      <lookup name="transparency">
        <lookup name="settings">KgxWindow</lookup>
      </lookup>
    </binding>
    <signal name="notify::fullscreened" handler="fullscreened_changed" swapped="yes" />
    <property name="width-request">360</property>
    <property name="height-request">294</property>
    <property name="content">
      <object class="GtkOverlay">
        <child>
          <object class="AdwToastOverlay" id="toasts">
        <property name="child">
          <object class="KgxFullscreenBox">
            <property name="fullscreen" bind-source="KgxWindow" bind-property="fullscreened"
              bind-flags="sync-create" />
            <property name="content">
              <object class="GtkStack" id="content_stack">
                <property name="transition-type">slide-down</property>
                <property name="transition-duration">200</property>
                <child>
                  <object class="GtkStackPage">
                    <property name="name">terminal</property>
                    <property name="child">
                      <object class="KgxPages" id="pages">
                        <property name="settings" bind-source="KgxWindow" bind-property="settings"
                          bind-flags="sync-create" />
                        <property name="is-active" bind-source="KgxWindow" bind-property="is-active"
                          bind-flags="sync-create" />
                        <signal name="zoom" handler="zoom" swapped="no" />
                        <signal name="create-tearoff-host" handler="create_tearoff_host"
                          swapped="no" />
                        <signal name="maybe-close-window" handler="maybe_close_window" swapped="yes" />
                        <signal name="notify::status" handler="status_changed" swapped="yes" />
                        <signal name="notify::title" handler="status_changed" swapped="yes" />
                        <signal name="notify::ringing" handler="ringing_changed" swapped="yes" />
                      </object>
                    </property>
                  </object>
                </child>
                <!-- Settings page created lazily on first use to avoid
                     icon lookup warnings during initial window show -->
              </object>
            </property>
            <child type="top">
              <object class="AdwHeaderBar" id="header_bar">
                <property name="show-start-title-buttons" bind-source="KgxWindow"
                  bind-property="fullscreened"
                  bind-flags="invert-boolean" />
                <property name="show-end-title-buttons" bind-source="KgxWindow"
                  bind-property="fullscreened"
                  bind-flags="invert-boolean" />
                <property name="title-widget">
                  <object class="AdwWindowTitle">
                    <binding name="subtitle">
                      <closure type='gchararray' function='kgx_file_as_subtitle'>
                        <lookup name="path">pages</lookup>
                        <lookup name="title">KgxWindow</lookup>
                      </closure>
                    </binding>
                    <property name="title" bind-source="KgxWindow" bind-property="title"
                      bind-flags="sync-create" />
                  </object>
                </property>
                <child type="start">
                  <object class="GtkToggleButton" id="search_button">
                    <property name="focus-on-click">False</property>
                    <property name="action-name">win.find</property>
                    <property name="tooltip-text" translatable="yes">Find in Terminal</property>
                    <property name="icon-name">edit-find-symbolic</property>
                  </object>
                </child>
                <child type="start">
                  <object class="GtkRevealer" id="search_revealer">
                    <property name="reveal-child" bind-source="KgxWindow"
                      bind-property="search-mode-enabled" bind-flags="sync-create" />
                    <property name="transition-type">swing-right</property>
                    <property name="transition-duration">150</property>
                    <signal name="notify::reveal-child" handler="search_enabled" swapped="no" />
                    <property name="child">
                      <object class="GtkBox">
                        <property name="spacing">6</property>
                        <child>
                          <object class="GtkSearchEntry" id="search_entry">
                            <property name="placeholder-text" translatable="yes">Find</property>
                            <property name="hexpand">1</property>
                            <property name="width-request">300</property>
                            <signal name="next-match" handler="search_next" swapped="no" />
                            <signal name="previous-match" handler="search_prev" swapped="no" />
                            <signal name="search-changed" handler="search_changed" swapped="no" />
                            <child>
                              <object class="GtkShortcutController">
                                <property name="propagation-phase">capture</property>
                                <child>
                                  <object class="GtkShortcut">
                                    <property name="trigger">Return</property>
                                    <property name="action">signal(next-match)</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkShortcut">
                                    <property name="trigger">&lt;shift&gt;Return</property>
                                    <property name="action">signal(previous-match)</property>
                                  </object>
                                </child>
                                <child>
                                  <object class="GtkShortcut">
                                    <property name="trigger">Escape</property>
                                    <property name="action">action(win.find)</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton">
                            <property name="receives-default">1</property>
                            <property name="icon-name">go-up-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Previous Match</property>
                            <signal name="clicked" handler="search_prev" swapped="no" />
                          </object>
                        </child>
                        <child>
                          <object class="GtkButton">
                            <property name="receives-default">1</property>
                            <property name="icon-name">go-down-symbolic</property>
                            <property name="tooltip-text" translatable="yes">Next Match</property>
                            <signal name="clicked" handler="search_next" swapped="no" />
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton">
                    <property name="visible" bind-source="KgxWindow"
                      bind-property="fullscreened"
                      bind-flags="sync-create" />
                    <property name="can-focus">0</property>
                    <property name="receives-default">0</property>
                    <property name="icon-name">view-restore-symbolic</property>
                    <property name="tooltip-text" translatable="yes">Leave Fullscreen</property>
                    <property name="action-name">win.unfullscreen</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkToggleButton">
                    <property name="focus-on-click">False</property>
                    <property name="tooltip-text" translatable="yes">Settings</property>
                    <property name="icon-name">emblem-system-symbolic</property>
                    <property name="action-name">win.toggle-settings</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton">
                    <property name="focus-on-click">False</property>
                    <property name="action-name">win.new-window</property>
                    <property name="tooltip-text" translatable="yes">New Window</property>
                    <property name="icon-name">window-new-symbolic</property>
                  </object>
                </child>
                <child type="end">
                  <object class="GtkButton">
                    <property name="focus-on-click">False</property>
                    <property name="action-name">win.new-tab</property>
                    <property name="tooltip-text" translatable="yes">New Tab</property>
                    <property name="icon-name">tab-new-symbolic</property>
                  </object>
                </child>
              </object>
            </child>
            <child type="top">
              <object class="AdwTabBar" id="tab_bar">
                <property name="view" bind-source="pages" bind-property="tab-view"
                  bind-flags="sync-create" />
                <binding name="inverted">
                  <closure type='gboolean' function='kgx_decoration_layout_is_inverted'>
                    <lookup name="gtk-decoration-layout">
                      <closure type='GtkSettings' function='kgx_gtk_settings_for_display'>
                        <lookup name="display">KgxWindow</lookup>
                      </closure>
                    </lookup>
                  </closure>
                </binding>
                <signal name="extra-drag-drop" handler="extra_drag_drop" swapped="no" />
              </object>
            </child>
          </object>
        </property>
      </object>
        </child>
        <child type="overlay">
          <object class="KgxEdge" id="edge">
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <binding name="overscroll-enabled">
