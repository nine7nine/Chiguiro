<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <template class="KgxSettingsPage" parent="AdwBin">
    <property name="child">
      <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="spacing">8</property>
            <property name="margin-bottom">260</property>

        <!-- ═══ Static About Section (always visible) ═══ -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="spacing">4</property>
            <property name="margin-top">16</property>
            <child>
              <object class="GtkPicture" id="logo_picture">
                <property name="can-shrink">False</property>
                <property name="halign">center</property>
                <property name="content-fit">contain</property>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">· C h i g ü i r o ·</property>
                <property name="use-markup">True</property>
                <style>
                  <class name="title-1" />
                </style>
                <attributes>
                  <attribute name="weight" value="bold" />
                  <attribute name="scale" value="1.4" />
                  <attribute name="letter-spacing" value="4096" />
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkLabel" id="version_label">
                <property name="label">v0.01-alpha</property>
                <style>
                  <class name="about-accent" />
                </style>
              </object>
            </child>
            <child>
              <object class="GtkLabel">
                <property name="label" translatable="yes">© 2026 Jordan Johnston</property>
                <style>
                  <class name="about-accent" />
                </style>
              </object>
            </child>
            <child>
              <object class="GtkBox">
                <property name="orientation">horizontal</property>
                <property name="halign">center</property>
                <property name="spacing">12</property>
                <child>
                  <object class="GtkLinkButton">
                    <property name="label" translatable="yes">Github</property>
                    <property name="uri">https://github.com/nine7nine/Chiguiro</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLinkButton">
                    <property name="label" translatable="yes">Issues</property>
                    <property name="uri">https://github.com/nine7nine/Chiguiro/issues</property>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- ═══ Page indicator + dots ═══ -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="spacing">4</property>
            <property name="margin-top">4</property>
            <property name="margin-bottom">4</property>
            <child>
              <object class="GtkLabel" id="page_title">
                <property name="label" translatable="yes">· General ·</property>
                <style>
                  <class name="title-1" />
                </style>
                <attributes>
                  <attribute name="weight" value="bold" />
                  <attribute name="scale" value="1.15" />
                </attributes>
              </object>
            </child>
            <child>
              <object class="AdwCarouselIndicatorDots">
                <property name="carousel">carousel</property>
              </object>
            </child>
          </object>
        </child>

        <!-- ═══ Carousel (paginated settings) ═══ -->
        <child>
          <object class="AdwCarousel" id="carousel">
            <property name="hexpand">True</property>
            <property name="allow-mouse-drag">True</property>
            <property name="allow-scroll-wheel">True</property>
            <property name="allow-long-swipes">True</property>
            <property name="spacing">0</property>

            <!-- ── Page 1: General ── -->
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">900</property>
                <property name="valign">start</property>
                <property name="hexpand">True</property>
                <property name="margin-top">8</property>
                <property name="margin-bottom">12</property>
                <property name="margin-start">24</property>
                <property name="margin-end">24</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>

                        <!-- Font Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Font</property>
                            <child>
                              <object class="AdwSwitchRow" id="use_system_font">
                                <property name="title" translatable="yes">Use _System Default</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="custom_font">
                                <property name="title" translatable="yes">Custom _Font</property>
                                <property name="use-underline">True</property>
                                <property name="activatable">True</property>
                                <property name="action-name">settings.select-font</property>
                                <child type="suffix">
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <binding name="attributes">
                                          <closure type="PangoAttrList" function="font_as_attributes">
                                            <lookup name="custom-font">
                                              <lookup name="settings">KgxSettingsPage</lookup>
                                            </lookup>
                                          </closure>
                                        </binding>
                                        <binding name="label">
                                          <closure type="gchararray" function="font_as_label">
                                            <lookup name="custom-font">
                                              <lookup name="settings">KgxSettingsPage</lookup>
                                            </lookup>
                                          </closure>
                                        </binding>
                                        <property name="ellipsize">middle</property>
                                        <style>
                                          <class name="dim-label" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">go-next-symbolic</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="text_scale">
                                <property name="title" translatable="yes">Text _Scale</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">50</property>
                                    <property name="upper">400</property>
                                    <property name="page-increment">25</property>
                                    <property name="step-increment">10</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Appearance Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Appearance</property>
                            <child>
                              <object class="AdwSpinRow" id="transparency_level">
                                <property name="title" translatable="yes">Window _Opacity</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">100</property>
                                    <property name="page-increment">10</property>
                                    <property name="step-increment">1</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="glass_opacity">
                                <property name="title" translatable="yes">Glass _Opacity</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">100</property>
                                    <property name="page-increment">10</property>
                                    <property name="step-increment">1</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="use_glass_bg">
                                <property name="title" translatable="yes">Use Glass Color for Terminal</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Glass _Color</property>
                                <property name="use-underline">True</property>
                                <property name="activatable-widget">glass_color</property>
                                <child type="suffix">
                                  <object class="GtkColorDialogButton" id="glass_color"><property name="dialog"><object class="GtkColorDialog"><property name="with-alpha">False</property></object></property>
                                    <property name="valign">center</property>
                                    <property name="margin-top">8</property>
                                    <property name="margin-bottom">8</property>
                                    <property name="dialog">
                                      <object class="GtkColorDialog">
                                        <property name="with-alpha">False</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Accent _Color</property>
                                <property name="use-underline">True</property>
                                <property name="activatable-widget">accent_color</property>
                                <child type="suffix">
                                  <object class="GtkColorDialogButton" id="accent_color"><property name="dialog"><object class="GtkColorDialog"><property name="with-alpha">False</property></object></property>
                                    <property name="valign">center</property>
                                    <property name="margin-top">8</property>
                                    <property name="margin-bottom">8</property>
                                    <property name="dialog">
                                      <object class="GtkColorDialog">
                                        <property name="with-alpha">False</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Behavior Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Behavior</property>
                            <child>
                              <object class="AdwSwitchRow" id="unlimited_scrollback">
                                <property name="title" translatable="yes">_Unlimited Scrollback</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="scrollback">
                                <property name="title" translatable="yes">_Scrollback Lines</property>
                                <property name="use-underline">True</property>
                                <property name="sensitive" bind-source="unlimited_scrollback" bind-property="active"
                                  bind-flags="sync-create|invert-boolean" />
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">800000</property>
                                    <property name="page-increment">1000</property>
                                    <property name="step-increment">1000</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Terminal Bell Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Terminal Bell</property>
                            <property name="description" translatable="yes">Control how alerts are indicated</property>
                            <child>
                              <object class="AdwSwitchRow" id="audible_bell">
                                <property name="title" translatable="yes">Play _Sound</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="visual_bell">
                                <property name="title" translatable="yes">_Visual Effects</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                      </object>
                  </property>
              </object>
            </child>

            <!-- ── Page 2: Particles ── -->
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">900</property>
                <property name="valign">start</property>
                <property name="hexpand">True</property>
                <property name="margin-top">24</property>
                <property name="margin-bottom">12</property>
                <property name="margin-start">24</property>
                <property name="margin-end">24</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>

                    <!-- Tunables grid -->
                    <child>
                      <object class="GtkGrid">
                        <property name="halign">center</property>
                        <property name="row-spacing">6</property>
                        <property name="column-spacing">14</property>
                        <property name="column-homogeneous">False</property>
                        <style><class name="preset-row"/></style>

                        <!-- Row 0: Headers -->
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Tunables</property><property name="xalign">0</property><style><class name="title-4"/></style><layout><property name="column">0</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Spd</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">1</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Thk</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">2</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Tail</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">3</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">P.Dep</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">4</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">P.Spd</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">5</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Atk</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">6</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Rel</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">7</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Rls</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">8</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label"></property><layout><property name="column">9</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Bst</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">10</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Spr</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">11</property><property name="row">0</property></layout></object></child>

                        <!-- Row 1: Overscroll -->
                        <child><object class="GtkLabel"><property name="label">Overscroll</property><property name="xalign">0</property><style><class name="preset-overscroll"/></style><layout><property name="column">0</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_speed"><property name="xalign">1</property><property name="digits">1</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">1</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_thickness"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">2</property><property name="upper">40</property><property name="step-increment">1</property></object></property><layout><property name="column">2</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_tail_length"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">3</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_pulse_depth"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">100</property><property name="step-increment">5</property></object></property><layout><property name="column">4</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_pulse_speed"><property name="xalign">1</property><property name="digits">1</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">500</property><property name="step-increment">10</property></object></property><layout><property name="column">5</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_env_attack"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Attack</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">50</property><property name="step-increment">5</property></object></property><layout><property name="column">6</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_env_release"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Release</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">50</property><property name="step-increment">5</property></object></property><layout><property name="column">7</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkToggleButton" id="edge_release_mode"><property name="label">R</property><property name="tooltip-text">Tail retraction on release</property><style><class name="flat"/><class name="release-toggle"/></style><layout><property name="column">8</property><property name="row">1</property></layout></object></child>
                        <child><object class="GtkButton" id="edge_shape"><property name="label">&#x25A0;</property><property name="tooltip-text">Particle shape</property><style><class name="flat"/></style><layout><property name="column">9</property><property name="row">1</property></layout></object></child>

                        <!-- Row 2: Ambient -->
                        <child><object class="GtkLabel"><property name="label">Ambient</property><property name="xalign">0</property><style><class name="preset-ambient"/></style><layout><property name="column">0</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_speed_ambient"><property name="xalign">1</property><property name="digits">1</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">1</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_thickness_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">2</property><property name="upper">40</property><property name="step-increment">1</property></object></property><layout><property name="column">2</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_tail_length_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">3</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_pulse_depth_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">100</property><property name="step-increment">5</property></object></property><layout><property name="column">4</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_pulse_speed_ambient"><property name="xalign">1</property><property name="digits">1</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">500</property><property name="step-increment">10</property></object></property><layout><property name="column">5</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_env_attack_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Attack</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">50</property><property name="step-increment">5</property></object></property><layout><property name="column">6</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_env_release_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Release</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">50</property><property name="step-increment">5</property></object></property><layout><property name="column">7</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkToggleButton" id="edge_release_mode_ambient"><property name="label">R</property><property name="tooltip-text">Tail retraction on release</property><style><class name="flat"/><class name="release-toggle"/></style><layout><property name="column">8</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkButton" id="edge_shape_ambient"><property name="label">&#x25A0;</property><property name="tooltip-text">Particle shape</property><style><class name="flat"/></style><layout><property name="column">9</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_burst_count_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Burst Count</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">1</property><property name="upper">8</property><property name="step-increment">1</property></object></property><layout><property name="column">10</property><property name="row">2</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_burst_spread_ambient"><property name="xalign">1</property><property name="digits">0</property><property name="tooltip-text">Burst Spread</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">50</property><property name="upper">500</property><property name="step-increment">10</property></object></property><layout><property name="column">11</property><property name="row">2</property></layout></object></child>

                        <!-- Row 3: Fireworks -->
                        <child><object class="GtkLabel"><property name="label">Fireworks</property><property name="xalign">0</property><style><class name="preset-fireworks"/></style><layout><property name="column">0</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_speed_fireworks"><property name="xalign">1</property><property name="digits">1</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">1</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_thickness_fireworks"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">2</property><property name="upper">40</property><property name="step-increment">1</property></object></property><layout><property name="column">2</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_tail_length_fireworks"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">10</property><property name="upper">300</property><property name="step-increment">10</property></object></property><layout><property name="column">3</property><property name="row">3</property></layout></object></child>
                        <child><object class="GtkSpinButton" id="edge_pulse_depth_fireworks"><property name="xalign">1</property><property name="digits">0</property><property name="adjustment"><object class="GtkAdjustment"><property name="lower">0</property><property name="upper">100</property><property name="step-increment">5</property></object></property><layout><property name="column">4</property><property name="row">3</property></layout></object></child>
