            </child>

            <!-- ── Page 4: Shortcuts ── -->
            <child>
              <object class="AdwClamp">
                <property name="maximum-size">900</property>
                <property name="valign">start</property>
                <property name="hexpand">True</property>
                <property name="margin-top">8</property>
                <property name="margin-bottom">12</property>
                <property name="margin-start">24</property>
                <property name="margin-end">24</property>
                <property name="child">
                  <object class="GtkBox">
                    <property name="orientation">vertical</property>
                    <property name="spacing">16</property>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Application</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">New Window</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;n</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Terminal</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Find</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;f</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Copy</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;c</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Paste</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;v</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Tabs</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">New Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;t</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Close Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;w</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Next Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;Page_Down</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Previous Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;Page_Up</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Switch to Tab 1–9</property>
                                <child type="suffix">
                                  <object class="GtkLabel">
                                    <property name="label">Alt + 1 … 9</property>
                                    <property name="valign">center</property>
                                    <style>
                                      <class name="dim-label" />
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Switch to Tab 10</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Alt&gt;0</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Window</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Fullscreen</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;F11</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                  </property>
              </object>
            </child>

          </object>
        </child>

      </object>
    </property>
  </template>
  <object class="GBindingGroup" id="settings_binds">
    <property name="source" bind-source="KgxSettingsPage" bind-property="settings"
      bind-flags="sync-create" />
  </object>
</interface>
