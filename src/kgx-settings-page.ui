<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0" />
  <template class="KgxSettingsPage" parent="AdwBin">
    <property name="child">
      <object class="GtkScrolledWindow">
            <property name="hexpand">True</property>
            <property name="vexpand">True</property>
            <property name="hscrollbar-policy">never</property>
            <property name="vscrollbar-policy">automatic</property>
            <property name="has-frame">False</property>
            <property name="propagate-natural-width">True</property>
            <property name="propagate-natural-height">False</property>
            <property name="child">
      <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="valign">start</property>
            <property name="spacing">8</property>
            <property name="margin-bottom">24</property>

        <!-- ═══ Static About Section (always visible) ═══ -->
        <child>
          <object class="GtkBox">
            <property name="orientation">horizontal</property>
            <property name="halign">center</property>
            <property name="valign">start</property>
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="halign">center</property>
                <property name="valign">start</property>
                <property name="spacing">4</property>
                <property name="margin-top">16</property>
                <child>
                  <object class="GtkPicture" id="logo_picture">
                    <property name="can-shrink">False</property>
                    <property name="halign">center</property>
                    <property name="content-fit">contain</property>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">· C h i g ü i r o ·</property>
                    <property name="use-markup">True</property>
                    <style>
                      <class name="title-1" />
                    </style>
                    <attributes>
                      <attribute name="weight" value="bold" />
                      <attribute name="scale" value="1.4" />
                      <attribute name="letter-spacing" value="4096" />
                    </attributes>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel" id="version_label">
                    <property name="label">v0.01-alpha</property>
                    <style>
                      <class name="about-accent" />
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkLabel">
                    <property name="label" translatable="yes">© 2026 Jordan Johnston</property>
                    <style>
                      <class name="about-accent" />
                    </style>
                  </object>
                </child>
                <child>
                  <object class="GtkBox">
                    <property name="orientation">horizontal</property>
                    <property name="halign">center</property>
                    <property name="spacing">12</property>
                    <child>
                      <object class="GtkLinkButton">
                        <property name="label" translatable="yes">Github</property>
                        <property name="uri">https://github.com/nine7nine/Chiguiro</property>
                      </object>
                    </child>
                    <child>
                      <object class="GtkLinkButton">
                        <property name="label" translatable="yes">Issues</property>
                        <property name="uri">https://github.com/nine7nine/Chiguiro/issues</property>
                      </object>
                    </child>
                  </object>
                </child>
              </object>
            </child>
          </object>
        </child>

        <!-- ═══ Page indicator + dots ═══ -->
        <child>
          <object class="GtkBox">
            <property name="orientation">vertical</property>
            <property name="halign">center</property>
            <property name="valign">start</property>
            <property name="spacing">4</property>
            <property name="margin-top">4</property>
            <property name="margin-bottom">4</property>
            <child>
              <object class="GtkLabel" id="page_title">
                <property name="label" translatable="yes">· General ·</property>
                <style>
                  <class name="title-1" />
                </style>
                <attributes>
                  <attribute name="weight" value="bold" />
                  <attribute name="scale" value="1.4" />
                </attributes>
              </object>
            </child>
            <child>
              <object class="GtkBox" id="page_dots">
                <property name="halign">center</property>
                <property name="spacing">8</property>
              </object>
            </child>
          </object>
        </child>

        <!-- ═══ Carousel (paginated settings) ═══ -->
        <child>
          <object class="AdwCarousel" id="carousel">
            <property name="hexpand">True</property>
            <property name="valign">start</property>
            <property name="allow-mouse-drag">True</property>
            <property name="allow-scroll-wheel">False</property>
            <property name="allow-long-swipes">True</property>
            <property name="spacing">0</property>

            <!-- ── Page 1: General ── -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="hexpand">True</property>
                <property name="halign">fill</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">900</property>
                    <property name="valign">start</property>
                    <property name="hexpand">True</property>
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>

                        <!-- Font Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Font</property>
                            <child>
                              <object class="AdwSwitchRow" id="use_system_font">
                                <property name="title" translatable="yes">Use _System Default</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow" id="custom_font">
                                <property name="title" translatable="yes">Custom _Font</property>
                                <property name="use-underline">True</property>
                                <property name="activatable">True</property>
                                <property name="action-name">settings.select-font</property>
                                <child type="suffix">
                                  <object class="GtkBox">
                                    <property name="spacing">6</property>
                                    <child>
                                      <object class="GtkLabel">
                                        <binding name="attributes">
                                          <closure type="PangoAttrList" function="font_as_attributes">
                                            <lookup name="custom-font">
                                              <lookup name="settings">KgxSettingsPage</lookup>
                                            </lookup>
                                          </closure>
                                        </binding>
                                        <binding name="label">
                                          <closure type="gchararray" function="font_as_label">
                                            <lookup name="custom-font">
                                              <lookup name="settings">KgxSettingsPage</lookup>
                                            </lookup>
                                          </closure>
                                        </binding>
                                        <property name="ellipsize">middle</property>
                                        <style>
                                          <class name="dim-label" />
                                        </style>
                                      </object>
                                    </child>
                                    <child>
                                      <object class="GtkImage">
                                        <property name="icon-name">go-next-symbolic</property>
                                        <property name="pixel-size">16</property>
                                      </object>
                                    </child>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="text_scale">
                                <property name="title" translatable="yes">Text _Scale</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">50</property>
                                    <property name="upper">400</property>
                                    <property name="page-increment">25</property>
                                    <property name="step-increment">10</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Appearance Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Appearance</property>
                            <child>
                              <object class="AdwSpinRow" id="transparency_level">
                                <property name="title" translatable="yes">Window _Opacity</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">100</property>
                                    <property name="page-increment">10</property>
                                    <property name="step-increment">1</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="glass_opacity">
                                <property name="title" translatable="yes">Glass _Opacity</property>
                                <property name="use-underline">True</property>
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">100</property>
                                    <property name="page-increment">10</property>
                                    <property name="step-increment">1</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="use_glass_bg">
                                <property name="title" translatable="yes">Use Glass Color for Terminal</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Glass _Color</property>
                                <property name="use-underline">True</property>
                                <property name="activatable-widget">glass_color</property>
                                <child type="suffix">
                                  <object class="GtkColorDialogButton" id="glass_color"><property name="dialog"><object class="GtkColorDialog"><property name="with-alpha">False</property></object></property>
                                    <property name="valign">center</property>
                                    <property name="margin-top">8</property>
                                    <property name="margin-bottom">8</property>
                                    <property name="dialog">
                                      <object class="GtkColorDialog">
                                        <property name="with-alpha">False</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Accent _Color</property>
                                <property name="use-underline">True</property>
                                <property name="activatable-widget">accent_color</property>
                                <child type="suffix">
                                  <object class="GtkColorDialogButton" id="accent_color"><property name="dialog"><object class="GtkColorDialog"><property name="with-alpha">False</property></object></property>
                                    <property name="valign">center</property>
                                    <property name="margin-top">8</property>
                                    <property name="margin-bottom">8</property>
                                    <property name="dialog">
                                      <object class="GtkColorDialog">
                                        <property name="with-alpha">False</property>
                                      </object>
                                    </property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Behavior Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Behavior</property>
                            <child>
                              <object class="AdwSwitchRow" id="unlimited_scrollback">
                                <property name="title" translatable="yes">_Unlimited Scrollback</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSpinRow" id="scrollback">
                                <property name="title" translatable="yes">_Scrollback Lines</property>
                                <property name="use-underline">True</property>
                                <property name="sensitive" bind-source="unlimited_scrollback" bind-property="active"
                                  bind-flags="sync-create|invert-boolean" />
                                <property name="numeric">True</property>
                                <property name="digits">0</property>
                                <property name="adjustment">
                                  <object class="GtkAdjustment">
                                    <property name="lower">0</property>
                                    <property name="upper">800000</property>
                                    <property name="page-increment">1000</property>
                                    <property name="step-increment">1000</property>
                                  </object>
                                </property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="command_complete_notifications">
                                <property name="title" translatable="yes">Desktop _Notifications</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                        <!-- Terminal Bell Group -->
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Terminal Bell</property>
                            <property name="description" translatable="yes">Control how alerts are indicated</property>
                            <child>
                              <object class="AdwSwitchRow" id="audible_bell">
                                <property name="title" translatable="yes">Play _Sound</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                            <child>
                              <object class="AdwSwitchRow" id="visual_bell">
                                <property name="title" translatable="yes">_Visual Effects</property>
                                <property name="use-underline">True</property>
                              </object>
                            </child>
                          </object>
                        </child>

                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>

            <!-- ── Page 2: App Glass ── -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="hexpand">True</property>
                <property name="halign">fill</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">900</property>
                    <property name="valign">start</property>
                    <property name="hexpand">True</property>
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="child">
                      <object class="GtkGrid" id="app_glass_grid">
                        <property name="row-spacing">4</property>
                        <property name="column-spacing">6</property>
                        <style><class name="preset-row"/></style>
                        <!-- Indicator + process rows built programmatically -->
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>

            <!-- ── Page 3: Particles ── -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="hexpand">True</property>
                <property name="halign">fill</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">900</property>
                    <property name="valign">start</property>
                    <property name="hexpand">True</property>
                    <property name="margin-top">24</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>

                    <!-- Ambient animation toggle -->
                    <child>
                      <object class="GtkBox">
                        <property name="spacing">8</property>
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Ambient/Settings</property><property name="hexpand">True</property><property name="xalign">0</property><style><class name="title-4"/></style></object></child>
                        <child><object class="GtkSwitch" id="ambient_switch"><property name="valign">center</property></object></child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox">
                        <property name="spacing">8</property>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Throttle Particle Redraw</property>
                            <property name="hexpand">True</property>
                            <property name="xalign">0</property>
                            <property name="tooltip-text" translatable="yes">Cap particle redraw rate and let the governor back off under load. Turn this off to redraw on every animation frame.</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSwitch" id="particle_throttle_switch">
                            <property name="valign">center</property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <child>
                      <object class="GtkBox" id="particle_hz_row">
                        <property name="spacing">8</property>
                        <property name="sensitive" bind-source="particle_throttle_switch" bind-property="active" bind-flags="sync-create"/>
                        <child>
                          <object class="GtkLabel">
                            <property name="label" translatable="yes">Particle Hz</property>
                            <property name="hexpand">True</property>
                            <property name="xalign">0</property>
                            <property name="tooltip-text" translatable="yes">Nominal redraw rate for all edge particles. The governor reduces this temporarily under load.</property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkSpinButton" id="particle_hz">
                            <property name="valign">center</property>
                            <property name="numeric">True</property>
                            <property name="digits">0</property>
                            <property name="width-chars">3</property>
                            <property name="adjustment">
                              <object class="GtkAdjustment">
                                <property name="lower">10</property>
                                <property name="upper">60</property>
                                <property name="step-increment">1</property>
                                <property name="page-increment">5</property>
                              </object>
                            </property>
                          </object>
                        </child>
                        <child>
                          <object class="GtkLabel">
                            <property name="label">Hz</property>
                            <property name="valign">center</property>
                          </object>
                        </child>
                      </object>
                    </child>

                    <!-- Tunables grid -->
                    <child>
                      <object class="GtkGrid" id="tunables_grid">
                        <property name="halign">center</property>
                        <property name="row-spacing">6</property>
                        <property name="column-spacing">14</property>
                        <property name="column-homogeneous">False</property>
                        <style><class name="preset-row"/></style>

                        <!-- Row 0: Headers -->
                        <child><object class="GtkLabel"><property name="label" translatable="yes">Tunables</property><property name="xalign">0</property><style><class name="title-4"/></style><layout><property name="column">0</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Spd</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">1</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Thk</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">2</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Gap</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">3</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Tail</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">4</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">P.Dep</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">5</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">P.Spd</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">6</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Atk</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">7</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Rel</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">8</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Rls</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">9</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label"></property><layout><property name="column">10</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Bst</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">11</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Spr</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">12</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">Crv</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">13</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">T.Atk</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">14</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">T.Rel</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">15</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">T.Rls</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">16</property><property name="row">0</property></layout></object></child>
                        <child><object class="GtkLabel"><property name="label">T.Crv</property><property name="xalign">1</property><style><class name="tune-header"/></style><layout><property name="column">17</property><property name="row">0</property></layout></object></child>
                        <!-- Preset rows (1-7) built programmatically -->
                      </object>
                    </child>

                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>

            <!-- ── Page 4: Shortcuts ── -->
            <child>
              <object class="GtkBox">
                <property name="orientation">vertical</property>
                <property name="hexpand">True</property>
                <property name="halign">fill</property>
                <child>
                  <object class="AdwClamp">
                    <property name="maximum-size">900</property>
                    <property name="valign">start</property>
                    <property name="hexpand">True</property>
                    <property name="margin-top">8</property>
                    <property name="margin-bottom">12</property>
                    <property name="margin-start">24</property>
                    <property name="margin-end">24</property>
                    <property name="child">
                      <object class="GtkBox">
                        <property name="orientation">vertical</property>
                        <property name="spacing">16</property>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Application</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">New Window</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;n</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Terminal</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Find</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;f</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Copy</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;c</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Paste</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;v</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Tabs</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">New Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;t</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Close Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;w</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Next Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;Page_Down</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Previous Tab</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Primary&gt;Page_Up</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Switch to Tab 1–9</property>
                                <child type="suffix">
                                  <object class="GtkLabel">
                                    <property name="label">Alt + 1 … 9</property>
                                    <property name="valign">center</property>
                                    <style>
                                      <class name="dim-label" />
                                    </style>
                                  </object>
                                </child>
                              </object>
                            </child>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Switch to Tab 10</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Alt&gt;0</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                        <child>
                          <object class="AdwPreferencesGroup">
                            <property name="title" translatable="yes">Window</property>
                            <child>
                              <object class="AdwActionRow">
                                <property name="title" translatable="yes">Fullscreen</property>
                                <child type="suffix">
                                  <object class="GtkShortcutLabel">
                                    <property name="accelerator">&lt;Shift&gt;&lt;Primary&gt;F11</property>
                                    <property name="valign">center</property>
                                  </object>
                                </child>
                              </object>
                            </child>
                          </object>
                        </child>
                      </object>
                    </property>
                  </object>
                </child>
              </object>
            </child>

          </object>
        </child>

      </object>
            </property>
      </object>
    </property>
  </template>
  <object class="GBindingGroup" id="settings_binds">
    <property name="source" bind-source="KgxSettingsPage" bind-property="settings"
      bind-flags="sync-create" />
  </object>
</interface>
